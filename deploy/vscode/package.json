{
  "name": "autopentest",
  "displayName": "autopentest — AI Penetration Testing",
  "description": "Autonomous AI-powered penetration testing from your IDE. Scan targets, view findings inline, and generate reports.",
  "version": "0.1.0",
  "publisher": "armurai",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Armur-Ai/autopentest"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Testing", "Linters", "Other"],
  "keywords": ["security", "penetration-testing", "vulnerability", "scanner", "pentest", "ai"],
  "activationEvents": [
    "onCommand:autopentest.scan",
    "onCommand:autopentest.explain",
    "workspaceContains:config.yaml",
    "workspaceContains:autopentest.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autopentest.scan",
        "title": "AutoPentest: Scan Target",
        "category": "AutoPentest"
      },
      {
        "command": "autopentest.explain",
        "title": "AutoPentest: Explain Finding",
        "category": "AutoPentest"
      },
      {
        "command": "autopentest.stop",
        "title": "AutoPentest: Stop Campaign",
        "category": "AutoPentest"
      },
      {
        "command": "autopentest.viewReport",
        "title": "AutoPentest: View Report",
        "category": "AutoPentest"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autopentest",
          "title": "AutoPentest",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "autopentest": [
        {
          "id": "autopentest.findings",
          "name": "Findings"
        },
        {
          "id": "autopentest.campaigns",
          "name": "Campaigns"
        }
      ]
    },
    "configuration": {
      "title": "AutoPentest",
      "properties": {
        "autopentest.apiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the autopentest API server"
        },
        "autopentest.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
